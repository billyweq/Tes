<!DOCTYPE html>

<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grow Seed — Bibit Unggul Bersertifikat</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:#fff;color:#1a1a1a;overflow-x:hidden}
:root{
  --green:#1b4d2e;--green-mid:#2d7a3f;--green-light:#e8f5ec;
  --red:#c0392b;--gold:#c8a040;--orange:#d4651a;
  --gray:#f5f5f5;--border:#e5e5e5;--text:#1a1a1a;--muted:#666;
}

/* ── BANNER PROMO ── */
.promo-banner{
background:linear-gradient(90deg,var(–red),#e74c3c,var(–red));
background-size:200% 100%;
animation:shimmer 3s linear infinite;
color:white;text-align:center;
padding:.65rem 1rem;font-size:.82rem;font-weight:600;
letter-spacing:.5px;
display:flex;align-items:center;justify-content:center;gap:.75rem;
}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.promo-close{
position:absolute;right:1.5rem;
background:none;border:none;color:white;
font-size:1.1rem;cursor:pointer;opacity:.7;
transition:opacity .2s;
}
.promo-close:hover{opacity:1}

/* ── NAV ── */
nav{
background:#fff;border-bottom:1px solid var(–border);
padding:.85rem 5%;
display:flex;align-items:center;justify-content:space-between;
position:sticky;top:0;z-index:100;
box-shadow:0 2px 12px rgba(0,0,0,0.06);
}
.logo img{height:48px;object-fit:contain}

.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{
text-decoration:none;color:var(–text);
font-size:.88rem;font-weight:500;
position:relative;padding-bottom:2px;
transition:color .2s;
}
.nav-links a::after{
content:’’;position:absolute;bottom:0;left:0;right:0;
height:2px;background:var(–green);
transform:scaleX(0);transition:transform .25s;
}
.nav-links a:hover{color:var(–green)}
.nav-links a:hover::after{transform:scaleX(1)}

.nav-right{display:flex;align-items:center;gap:.75rem}
.nav-wa{
background:var(–green);color:white;text-decoration:none;
padding:.5rem 1.2rem;border-radius:6px;
font-size:.85rem;font-weight:600;
display:flex;align-items:center;gap:7px;
transition:background .2s;
}
.nav-wa:hover{background:var(–green-mid)}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px}
.hamburger span{width:22px;height:2px;background:var(–text);border-radius:2px;transition:all .3s}

/* ── HERO ── */
.hero{
padding:5rem 5% 4rem;background:#fff;
border-bottom:1px solid var(–border);
}
.hero-inner{
max-width:1200px;margin:0 auto;
display:grid;grid-template-columns:1fr 1fr;
gap:4rem;align-items:center;
}
.hero-eyebrow{font-size:.78rem;font-weight:700;letter-spacing:2px;color:var(–red);text-transform:uppercase;margin-bottom:.5rem}
.hero-title{font-family:‘Fraunces’,serif;font-size:clamp(3rem,5vw,5rem);font-weight:900;line-height:1;margin-bottom:.5rem}
.hero-tagline{font-size:1.2rem;font-weight:600;color:var(–text);margin-bottom:1.2rem}
.hero-desc{font-size:.9rem;color:var(–muted);line-height:1.9;max-width:480px;margin-bottom:2rem}
.hero-img-wrap{position:relative;overflow:hidden;border-radius:16px}
.hero-img{
width:100%;max-height:500px;object-fit:contain;
transition:transform .5s cubic-bezier(.34,1.56,.64,1);
filter:drop-shadow(0 20px 40px rgba(27,77,46,.2));
}
.hero-img-wrap:hover .hero-img{transform:scale(1.06) rotate(-1deg)}
.btn-green{
display:inline-flex;align-items:center;gap:8px;
background:var(–green);color:white;text-decoration:none;
padding:.85rem 2rem;font-size:.9rem;font-weight:700;
border-radius:6px;transition:background .2s,transform .15s;
border:none;cursor:pointer;
}
.btn-green:hover{background:var(–green-mid);transform:translateY(-2px)}

/* ── STATS ── */
.stats{background:var(–green);padding:2.5rem 5%}
.stats-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;text-align:center}
.stat-num{font-family:‘Fraunces’,serif;font-size:2.4rem;font-weight:900;color:#a8d878;line-height:1}
.stat-label{font-size:.75rem;color:rgba(255,255,255,.7);margin-top:4px;letter-spacing:.5px}

/* ── SECTION ── */
.section{padding:5rem 5%}
.section-inner{max-width:1200px;margin:0 auto}
.eyebrow{font-size:.75rem;font-weight:700;letter-spacing:2px;color:var(–red);text-transform:uppercase;margin-bottom:.4rem}
.sec-title{font-family:‘Fraunces’,serif;font-size:clamp(1.8rem,3vw,2.6rem);font-weight:900;margin-bottom:3rem;line-height:1.15}

/* ── PRODUCTS ── */
.product-list{display:flex;flex-direction:column;gap:0;max-width:1200px;margin:0 auto}
.product-item{
display:grid;grid-template-columns:1fr 1fr;
border-top:1px solid var(–border);
}
.product-item:last-child{border-bottom:1px solid var(–border)}
.product-item.reverse .prod-img-wrap{order:-1}

.prod-content{
padding:3.5rem 4rem 3.5rem 0;
display:flex;flex-direction:column;justify-content:center;
}
.product-item.reverse .prod-content{padding:3.5rem 0 3.5rem 4rem}

.prod-eyebrow{font-size:.72rem;font-weight:700;letter-spacing:2px;color:var(–red);text-transform:uppercase;margin-bottom:.3rem}
.prod-name{font-family:‘Fraunces’,serif;font-size:clamp(2rem,3.5vw,3rem);font-weight:900;line-height:1;margin-bottom:.4rem}
.prod-tagline{font-size:1rem;font-weight:600;margin-bottom:.9rem}
.prod-desc{font-size:.86rem;color:var(–muted);line-height:1.85;max-width:420px;margin-bottom:1.3rem}
.prod-specs{display:flex;gap:.6rem;flex-wrap:wrap;margin-bottom:1.4rem}
.prod-spec-tag{
background:var(–green-light);color:var(–green);
font-size:.72rem;font-weight:600;padding:3px 11px;border-radius:50px;
}

/* HOVER EFFECT ON PRODUCT IMAGE */
.prod-img-wrap{
background:var(–gray);
display:flex;align-items:center;justify-content:center;
padding:2.5rem;min-height:340px;overflow:hidden;
cursor:pointer;position:relative;
}
.prod-img-wrap::after{
content:‘🔍 Lihat Detail’;
position:absolute;bottom:1.2rem;left:50%;
transform:translateX(-50%) translateY(20px);
background:rgba(27,77,46,.85);color:white;
padding:.45rem 1.1rem;border-radius:50px;
font-size:.75rem;font-weight:600;
opacity:0;transition:all .3s;white-space:nowrap;
}
.prod-img-wrap:hover::after{opacity:1;transform:translateX(-50%) translateY(0)}

.prod-img{
max-width:100%;max-height:300px;object-fit:contain;
transition:transform .5s cubic-bezier(.34,1.56,.64,1),filter .3s;
filter:drop-shadow(0 8px 24px rgba(0,0,0,.1));
}
.prod-img-wrap:hover .prod-img{
transform:scale(1.08) rotate(-2deg);
filter:drop-shadow(0 16px 36px rgba(27,77,46,.2));
}

.prod-emoji{font-size:7rem;transition:transform .5s cubic-bezier(.34,1.56,.64,1)}
.prod-img-wrap:hover .prod-emoji{transform:scale(1.15) rotate(-5deg) translateY(-8px)}

/* ── POPUP MODAL ── */
.modal-overlay{
position:fixed;inset:0;background:rgba(0,0,0,.6);
z-index:500;opacity:0;pointer-events:none;
transition:opacity .3s;display:flex;align-items:center;justify-content:center;
padding:1rem;
}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{
background:#fff;border-radius:20px;
max-width:800px;width:100%;max-height:90vh;overflow-y:auto;
transform:scale(.9) translateY(20px);
transition:transform .35s cubic-bezier(.34,1.56,.64,1);
position:relative;
}
.modal-overlay.open .modal{transform:scale(1) translateY(0)}

.modal-header{
display:grid;grid-template-columns:1fr 1fr;
border-bottom:1px solid var(–border);
}
.modal-img-side{
background:var(–gray);display:flex;
align-items:center;justify-content:center;
padding:2.5rem;border-radius:20px 0 0 0;
min-height:280px;
}
.modal-img-side img,.modal-img-side .modal-emoji{
max-height:220px;max-width:100%;object-fit:contain;
font-size:7rem;
}
.modal-info-side{padding:2rem 2rem 1.5rem}
.modal-eyebrow{font-size:.7rem;font-weight:700;letter-spacing:2px;color:var(–red);text-transform:uppercase;margin-bottom:.3rem}
.modal-name{font-family:‘Fraunces’,serif;font-size:2rem;font-weight:900;line-height:1;margin-bottom:.4rem}
.modal-tagline{font-size:.95rem;font-weight:600;margin-bottom:.75rem}
.modal-desc{font-size:.85rem;color:var(–muted);line-height:1.8;margin-bottom:1rem}
.modal-tags{display:flex;gap:.5rem;flex-wrap:wrap}
.modal-tag{background:var(–green-light);color:var(–green);font-size:.72rem;font-weight:600;padding:3px 11px;border-radius:50px}

.modal-body{padding:1.5rem 2rem 2rem}
.modal-specs-title{font-weight:700;font-size:.88rem;margin-bottom:.9rem;color:var(–text)}
.modal-specs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;margin-bottom:1.5rem}
.modal-spec-card{background:var(–gray);border-radius:10px;padding:1rem;text-align:center;border-left:3px solid var(–green)}
.modal-spec-val{font-family:‘Fraunces’,serif;font-size:1.2rem;font-weight:900;color:var(–green)}
.modal-spec-label{font-size:.7rem;color:var(–muted);margin-top:2px}

.modal-close{
position:absolute;top:1rem;right:1rem;
width:34px;height:34px;background:var(–gray);
border:none;border-radius:50%;cursor:pointer;
font-size:1rem;display:flex;align-items:center;justify-content:center;
transition:background .2s;z-index:10;
}
.modal-close:hover{background:#e0e0e0}

.modal-wa{
width:100%;display:flex;align-items:center;justify-content:center;gap:10px;
background:#25D366;color:white;text-decoration:none;
padding:1rem;border-radius:10px;font-size:.95rem;font-weight:700;
transition:background .2s;
}
.modal-wa:hover{background:#1ebe5d}

/* ── TESTIMONI ── */
.testi-section{background:#f9f9f9;padding:5rem 5%}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.testi-card{
background:#fff;border-radius:16px;padding:1.8rem;
border:1px solid var(–border);
transition:transform .25s,box-shadow .25s;
}
.testi-card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,.08)}
.testi-stars{color:#f39c12;font-size:1rem;margin-bottom:.75rem}
.testi-text{font-size:.88rem;color:var(–muted);line-height:1.8;margin-bottom:1.2rem;font-style:italic}
.testi-author{display:flex;align-items:center;gap:.75rem}
.testi-avatar{width:42px;height:42px;border-radius:50%;background:var(–green-light);display:flex;align-items:center;justify-content:center;font-size:1.2rem}
.testi-name{font-weight:600;font-size:.88rem}
.testi-loc{font-size:.75rem;color:var(–muted)}
.testi-product{display:inline-block;background:var(–green-light);color:var(–green);font-size:.7rem;font-weight:600;padding:2px 8px;border-radius:50px;margin-top:3px}

/* ── TENTANG ── */
.about-section{background:#fff;padding:5rem 5%}
.about-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.about-left h2{font-family:‘Fraunces’,serif;font-size:clamp(2rem,3.5vw,3rem);font-weight:900;line-height:1.1}
.about-right p{font-size:.92rem;color:var(–muted);line-height:1.9;margin-bottom:1.5rem}

/* ── KONTAK ── */
.kontak-section{background:var(–green);padding:4rem 5%}
.kontak-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1.5fr;gap:4rem;align-items:center}
.kontak-left h2{font-family:‘Fraunces’,serif;font-size:clamp(1.8rem,3vw,2.5rem);font-weight:900;color:white;margin-bottom:.75rem}
.kontak-left p{color:rgba(255,255,255,.7);font-size:.9rem;line-height:1.8}
.info-blocks{display:flex;flex-direction:column;gap:.9rem}
.info-block{background:rgba(255,255,255,.1);border-radius:10px;padding:1.1rem 1.3rem;display:flex;align-items:center;gap:1rem;border:1px solid rgba(255,255,255,.12)}
.info-block-icon{width:42px;height:42px;background:rgba(255,255,255,.12);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
.info-block-label{font-size:.7rem;color:rgba(255,255,255,.5);letter-spacing:.5px;margin-bottom:1px}
.info-block-val{font-weight:600;color:white;font-size:.92rem}
.info-block-sub{font-size:.75rem;color:rgba(255,255,255,.55);margin-top:1px}
.wa-cta{display:flex;align-items:center;justify-content:center;gap:10px;background:#25D366;color:white;text-decoration:none;padding:1rem 1.5rem;border-radius:10px;font-size:.95rem;font-weight:700;margin-top:1.2rem;transition:background .2s,transform .15s;box-shadow:0 6px 20px rgba(37,211,102,.3)}
.wa-cta:hover{background:#1ebe5d;transform:translateY(-2px)}

/* ── MAP ── */
.map-wrap iframe{width:100%;height:420px;display:block;border:none}

/* ── FOOTER ── */
footer{background:#111;padding:2.5rem 5%;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem}
.footer-logo img{height:42px;object-fit:contain;filter:brightness(10)}
footer p{color:#666;font-size:.8rem}

/* ── WA FLOAT ── */
.wa-float{
position:fixed;bottom:1.5rem;right:1.5rem;z-index:200;
background:#25D366;color:white;text-decoration:none;
padding:.8rem 1.3rem;border-radius:50px;
font-size:.88rem;font-weight:700;
display:flex;align-items:center;gap:9px;
box-shadow:0 6px 24px rgba(37,211,102,.5);
animation:popin .5s 1.2s cubic-bezier(.34,1.56,.64,1) both;
transition:transform .2s;
}
.wa-float:hover{transform:scale(1.05) translateY(-2px)}
@keyframes popin{from{opacity:0;transform:scale(.4) translateY(20px)}to{opacity:1;transform:scale(1) translateY(0)}}

/* ── SCROLL TOP ── */
.scroll-top{
position:fixed;bottom:5.5rem;right:1.5rem;z-index:200;
width:44px;height:44px;background:var(–green);color:white;
border:none;border-radius:12px;cursor:pointer;
display:flex;align-items:center;justify-content:center;
font-size:1.1rem;
box-shadow:0 4px 16px rgba(27,77,46,.3);
opacity:0;pointer-events:none;
transition:opacity .3s,transform .2s;
}
.scroll-top.show{opacity:1;pointer-events:all}
.scroll-top:hover{transform:translateY(-3px)}

/* ── REVEAL ── */
.reveal{opacity:0;transform:translateY(24px);transition:opacity .7s ease,transform .7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ── MOBILE ── */
@media(max-width:900px){
.hero-inner,.about-inner,.kontak-inner{grid-template-columns:1fr}
.product-item,.product-item.reverse{grid-template-columns:1fr}
.product-item.reverse .prod-img-wrap{order:0}
.prod-content,.product-item.reverse .prod-content{padding:2rem 1.5rem}
.modal-header{grid-template-columns:1fr}
.modal-img-side{border-radius:20px 20px 0 0;min-height:200px}
.testi-grid{grid-template-columns:1fr}
.stats-inner{grid-template-columns:1fr 1fr}
nav .nav-links{
display:none;position:fixed;top:0;left:0;right:0;bottom:0;
background:rgba(255,255,255,.98);flex-direction:column;
align-items:center;justify-content:center;gap:2rem;z-index:200;
}
nav .nav-links.open{display:flex}
nav .nav-links a{font-size:1.3rem}
.hamburger{display:flex}
.modal-specs-grid{grid-template-columns:1fr 1fr}
}
</style>

</head>
